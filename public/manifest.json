{
  "manifest_version": 3,
  "name": "Letterboxd Hours",
  "version": "1.0.0",
  "description": "Injects a total 'HOURS watched' statistic into Letterboxd user profiles.",
  "permissions": ["storage"],
  "host_permissions": ["*://letterboxd.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://letterboxd.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Letterboxd Hours"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
